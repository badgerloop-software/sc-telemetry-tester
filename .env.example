# InfluxDB — same variables as docker inference service / can-telem-cloud
INFLUXDB_URL=https://us-east-1-1.aws.cloud2.influxdata.com
INFLUXDB_TOKEN=your-token-here
INFLUXDB_ORG=your-org
INFLUXDB_BUCKET=your-bucket

# Production car layout (default): telemetry_snapshot,signal=<name> value=<n>
# INFLUXDB_MEASUREMENT=telemetry_snapshot
# INFLUX_WRITE_MODE=production

# Flat fields for inference testing (matches docker /predict defaults):
# INFLUX_WRITE_MODE=flat
# INFLUXDB_MEASUREMENT=telemetry
# INFLUXDB_FIELDS=soc,pack_power,air_temp
